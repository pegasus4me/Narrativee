# Optional future LLM provider configuration.
LLM_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

RAG_PROVIDER=pinecone
PINECONE_RAG_API_KEY=
PINECONE_RAG_INDEX_NAME=narrativee-rag
PINECONE_RAG_HOST=
PINECONE_RAG_NAMESPACE=
PINECONE_RAG_TEXT_FIELD=chunk_text
PINECONE_RAG_RERANK=true
PINECONE_RAG_RERANK_MODEL=bge-reranker-v2-m3
PINECONE_RAG_RERANK_TOP_N=8

# Pinecone-backed creator memory configuration.
MEMORY_PROVIDER=pinecone
PINECONE_MEMORY_API_KEY=
PINECONE_MEMORY_INDEX_NAME=narrativee
PINECONE_MEMORY_HOST=
PINECONE_MEMORY_NAMESPACE=
PINECONE_MEMORY_TEXT_FIELD=chunk_text
PINECONE_MEMORY_CREATE_INDEX=false
PINECONE_MEMORY_CLOUD=aws
PINECONE_MEMORY_REGION=us-east-1
PINECONE_MEMORY_EMBEDDING_MODEL=llama-text-embed-v2
PINECONE_MEMORY_RERANK=true
PINECONE_MEMORY_RERANK_MODEL=bge-reranker-v2-m3
PINECONE_MEMORY_RERANK_TOP_N=8
