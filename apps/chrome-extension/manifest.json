{
    "manifest_version": 3,
    "name": "Substack Comment Wizard",
    "version": "1.0.0",
    "description": "Generate AI-powered comments on Substack Notes with one click 🧙‍♂️",
    "permissions": [
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "*://*.substack.com/*"
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background/service-worker.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.substack.com/*"
            ],
            "js": [
                "content/content.js"
            ],
            "css": [
                "styles/inject.css"
            ]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}