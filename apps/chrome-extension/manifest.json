{
    "manifest_version": 3,
    "name": "Narrativee",
    "version": "1.0.12",
    "description": "Your AI copilot for Substack growth and engagement.",
    "permissions": [
        "activeTab",
        "storage",
        "alarms",
        "tabs"
    ],
    "host_permissions": [
        "*://*.substack.com/*",
        "http://localhost:3000/*",
        "http://localhost:3002/*",
        "http://localhost:3010/*",
        "*://*.narrativee.com/*"
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background/service-worker.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.substack.com/*",
                "http://localhost:3000/*",
                "http://localhost:3010/*",
                "*://*.narrativee.com/*"
            ],
            "js": [
                "content/content.js",
                "content/inspiration-saver.js",
                "content/engagement-scraper.js",
                "content/stats-scraper.js",
                "content/notes-scraper.js",
                "content/subs-scraper.js"
            ],
            "css": [
                "styles/inject.css"
            ]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}