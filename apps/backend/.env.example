# ─── Core ─────────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development
BACKEND_URL=http://localhost:3002
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/narrativee
# LOCAL_DATABASE_URL=           # Optional: override for local dev

# ─── Auth (Better Auth) ──────────────────────────────────────────────────────
BETTER_AUTH_SECRET=                # Generate: openssl rand -hex 32
BETTER_AUTH_URL=http://localhost:3002

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Encryption ───────────────────────────────────────────────────────────────
ENCRYPTION_KEY=                    # 64 hex chars (32 bytes). Generate: openssl rand -hex 32

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                 # sk_test_... (NEVER use sk_live_ in .env)
STRIPE_WEBHOOK_SECRET=             # whsec_...
# STRIPE_TEST_WEBHOOK_SECRET=      # For local Stripe CLI testing

# ─── LLM Providers ───────────────────────────────────────────────────────────
GROK_API_KEY=                      # xAI API key
XAI_API_KEY=                       # Alternative xAI key

# ─── Social OAuth (Channels) ─────────────────────────────────────────────────
X_CLIENT_ID=
X_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# META_APP_ID=                     # Facebook
# META_APP_SECRET=
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
# THREADS_APP_ID=
# THREADS_APP_SECRET=

# ─── Services ────────────────────────────────────────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
RESEND_API_KEY=                    # For transactional emails
PLACID_API_TOKEN=
PLACID_PUBLIC_TOKEN=
PLACID_INSTAGRAM_CAROUSEL_HOOK_TEMPLATE_ID=
PLACID_INSTAGRAM_CAROUSEL_INSIGHT_TEMPLATE_ID=
PLACID_INSTAGRAM_CAROUSEL_PROOF_TEMPLATE_ID=
PLACID_INSTAGRAM_CAROUSEL_CTA_TEMPLATE_ID=
PLACID_LINKEDIN_CAROUSEL_HOOK_TEMPLATE_ID=
PLACID_LINKEDIN_CAROUSEL_INSIGHT_TEMPLATE_ID=
PLACID_LINKEDIN_CAROUSEL_PROOF_TEMPLATE_ID=
PLACID_LINKEDIN_CAROUSEL_CTA_TEMPLATE_ID=

# ─── Deploy ──────────────────────────────────────────────────────────────────
# DEPLOY_HOOK_SECRET=              # Auth token for /api/deploy-hook
# DEPLOY_SCRIPT_PATH=/home/ubuntu/deploy.sh
